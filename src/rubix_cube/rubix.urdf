<?xml version="1.0" encoding="UTF-8"?>
<robot name="rubix_cube">

  <!-- s = 0.019m: center-to-center distance between adjacent cubies (57mm cube / 3) -->

  <!-- ======== CORE ======== -->
  <link name="base_link">
    <visual>
      <geometry><mesh filename="package://rubix_cube/meshes/Center_Part.stl"/></geometry>
      <material><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.057 0.057 0.057"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ======== TOP FACE (Z+, white) ======== -->
  <joint name="top_joint" type="revolute">
    <parent link="base_link"/><child link="top_face"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" effort="10" velocity="1"/>
  </joint>
  <link name="top_face">
    <inertial><mass value="0.05"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>

  <joint name="top_center_joint" type="fixed">
    <parent link="top_face"/><child link="top_center"/>
    <origin xyz="0 0 0.019" rpy="0 0 0"/>
  </joint>
  <link name="top_center">
    <visual><geometry><mesh filename="package://rubix_cube/meshes/Middle Square.stl"/></geometry><material><color rgba="1 1 1 1"/></material></visual>
    <inertial><mass value="0.005"/><inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/></inertial>
  </link>

  <joint name="top_front_edge_joint" type="fixed">
    <parent link="top_face"/><child link="top_front_edge"/>
    <origin xyz="0 0.019 0.019" rpy="0 0 0"/>
  </joint>
  <link name="top_front_edge">
    <visual><geometry><mesh filename="package://rubix_cube/meshes/Edge Square.stl"/></geometry><material><color rgba="1 1 1 1"/></material></visual>
    <inertial><mass value="0.005"/><inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/></inertial>
  </link>

  <joint name="top_back_edge_joint" type="fixed">
    <parent link="top_face"/><child link="top_back_edge"/>
    <origin xyz="0 -0.019 0.019" rpy="0 0 0"/>
  </joint>
  <link name="top_back_edge">
    <visual><geometry><mesh filename="package://rubix_cube/meshes/Edge Square.stl"/></geometry><material><color rgba="1 1 1 1"/></material></visual>
    <inertial><mass value="0.005"/><inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/></inertial>
  </link>

  <joint name="top_right_edge_joint" type="fixed">
    <parent link="top_face"/><child link="top_right_edge"/>
    <origin xyz="0.019 0 0.019" rpy="0 0 0"/>
  </joint>
  <link name="top_right_edge">
    <visual><geometry><mesh filename="package://rubix_cube/meshes/Edge Square.stl"/></geometry><material><color rgba="1 1 1 1"/></material></visual>
    <inertial><mass value="0.005"/><inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/></inertial>
  </link>

  <joint name="top_left_edge_joint" type="fixed">
    <parent link="top_face"/><child link="top_left_edge"/>
    <origin xyz="-0.019 0 0.019" rpy="0 0 0"/>
  </joint>
  <link name="top_left_edge">
