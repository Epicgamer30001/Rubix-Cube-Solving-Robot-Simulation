<?xml version="1.0" encoding="UTF-8"?>

<robot name="rubix_cube">

    <link name="my_link">
        <visual>
            
            <geometry>
                <mesh filename="package://rubix_cube/meshes/Center_Part.stl" scale="100 100 100"/>
            </geometry>
            <material>
                <color rgba="1 0 0 1"/>
            </material>
        </visual>

        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>


</robot>